NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SECRET_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Optional. When unset, the floating Project Copilot launcher is hidden and
# the rest of the app behaves identically.
NEXT_PUBLIC_AGENT_URL=http://localhost:8001

# Account invites (POST /api/admin/invite). Shared secret presented as
# `Authorization: Bearer <INVITE_SECRET>`. Requires SUPABASE_SECRET_KEY above
# (admin.generateLink) and the Resend vars below.
INVITE_SECRET=set-a-long-random-string
# Absolute site origin used to build invite/confirm links. Falls back to the
# request origin when unset (fine on Vercel).
NEXT_PUBLIC_SITE_URL=https://arro.co.nz

# Resend (waitlist + invite emails). When RESEND_API_KEY is unset, emails are
# skipped (dev-friendly). FROM must be on a domain verified in Resend.
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
WAITLIST_FROM_EMAIL=Arro <hello@arro.co.nz>
WAITLIST_REPLY_TO=arrotechnology@gmail.com
