{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "CAD scene projection",
  "description": "The engine→client contract. project_scene(doc) emits this render-ready, snap-aware scene. Versioned via the `version` field.",
  "version": "scene/v1",
  "type": "object",
  "required": ["version", "units", "extents", "entities", "snaps"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": "scene/v1" },
    "units": {
      "type": "string",
      "description": "Drawing units from $INSUNITS, e.g. 'mm', 'm', 'in', 'unitless', or 'code:N' for unmapped codes."
    },
    "extents": {
      "type": "array",
      "description": "Model-space bbox [x0, y0, x1, y1] covering all entities — used for model↔screen mapping.",
      "items": { "type": "number" },
      "minItems": 4,
      "maxItems": 4
    },
    "entities": {
      "type": "array",
      "items": { "$ref": "#/definitions/Entity" }
    },
    "snaps": {
      "type": "array",
      "description": "Flat list of snap targets feeding the client spatial index. Deduped by rounded (x, y); highest-priority kind wins (endpoint > center > intersection > midpoint).",
      "items": { "$ref": "#/definitions/Snap" }
    }
  },
  "definitions": {
    "Entity": {
      "type": "object",
      "required": ["handle", "type", "layer"],
      "properties": {
        "handle": { "type": "string", "description": "Stable ezdxf handle — the identity ops reference." },
        "type": { "type": "string", "description": "DXF type: LINE, LWPOLYLINE, POLYLINE, CIRCLE, ARC, TEXT, MTEXT, INSERT, DIMENSION." },
        "layer": { "type": "string" },
        "bbox": {
          "type": ["array", "null"],
          "items": { "type": "number" },
          "minItems": 4,
          "maxItems": 4
        },
        "start": { "type": "array", "items": { "type": "number" } },
        "end": { "type": "array", "items": { "type": "number" } },
        "points": { "type": "array", "items": { "type": "array", "items": { "type": "number" } } },
        "closed": { "type": "boolean" },
        "center": { "type": "array", "items": { "type": "number" } },
        "radius": { "type": "number" },
        "start_angle": { "type": "number" },
        "end_angle": { "type": "number" },
        "text": { "type": "string" },
        "insert": { "type": ["array", "null"], "items": { "type": "number" } },
        "height": { "type": "number" },
        "block": { "type": "string" },
        "scale": { "type": "array", "items": { "type": "number" } },
        "rotation": { "type": "number" },
        "measurement": { "type": "number" }
      }
    },
    "Snap": {
      "type": "object",
      "required": ["x", "y", "kind"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "kind": { "type": "string", "enum": ["endpoint", "midpoint", "center", "intersection"] },
        "handle": { "type": ["string", "null"], "description": "Source entity handle; null for intersections (which belong to two entities)." }
      },
      "additionalProperties": false
    },
    "OpDelta": {
      "type": "object",
      "description": "Returned by POST /cad/{id}/ops so the client reconciles its scene without a full reload. The three lists are disjoint.",
      "required": ["added", "removed", "changed"],
      "properties": {
        "added": { "type": "array", "items": { "type": "string" }, "description": "Handles of newly created entities." },
        "removed": { "type": "array", "items": { "type": "string" }, "description": "Handles of deleted entities." },
        "changed": { "type": "array", "items": { "type": "string" }, "description": "Handles of edited (moved/resized/relayered/attribute) entities." }
      },
      "additionalProperties": false
    }
  }
}
