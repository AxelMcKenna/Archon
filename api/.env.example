SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ─── Gemini (direct) ──────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_VERIFIER_MODEL=gemini-2.5-flash

# ─── OpenRouter ───────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
# Any model id OR exposes — e.g. openai/gpt-5, qwen/qwen2.5-vl-72b-instruct,
# google/gemini-2.5-pro, anthropic/claude-opus-4.7
OPENROUTER_MODEL=openai/gpt-chat-latest
OPENROUTER_VERIFIER_MODEL=openai/gpt-5.4-mini
OPENROUTER_REFERER=

# ─── Provider per touchpoint ──────────────────────────────────────────────
# Values: gemini | openrouter
PLAN_ANALYSER_PROVIDER=gemini
PLAN_VERIFIER_PROVIDER=gemini
RFI_EXTRACTOR_PROVIDER=gemini
CLASSIFIER_PROVIDER=gemini
DRAFTER_PROVIDER=gemini

# Self-consistency voting on the plan analyser. N parallel runs; keep
# flags appearing in >= threshold of them. N=1 disables voting (cheap).
PLAN_ANALYSER_VOTING_N=3
PLAN_ANALYSER_VOTING_THRESHOLD=2

# OCR fallback for flags whose quote isn't in the PDF text layer (typical
# when CAD vectorises drawing labels). Set to `false` to skip — useful on
# dev boxes where rapidocr-onnxruntime isn't installable.
PLAN_OCR_REFINER_ENABLED=true

ENV=dev
