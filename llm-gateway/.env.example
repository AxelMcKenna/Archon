# ─── OpenRouter (reused from api/) ───────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_REFERER=

# ─── Per-role models ─────────────────────────────────────────────────────
# Orchestrator runs the chat + tool-use loop. Sonnet 4.6 is the default for
# its tool-call accuracy and streaming support.
AGENT_ORCHESTRATOR_MODEL=anthropic/claude-sonnet-4.6
# One-shot summarizer (no tools) — used by /context/summary.
AGENT_SUMMARIZER_MODEL=google/gemini-2.5-flash
# Cheap utility model for titles, follow-up suggestions, etc.
AGENT_UTILITY_MODEL=anthropic/claude-haiku-4.5

# ─── Supabase (reused) ───────────────────────────────────────────────────
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=

# ─── Downstream FastAPI for tool execution ───────────────────────────────
API_BASE_URL=http://localhost:8000

# ─── CORS ────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

ENV=dev
